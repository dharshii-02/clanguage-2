#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char s[1001];
    int count[10] = {0}; // Initialize counts for digits 0-9 to zero

    // Read the input string
    if (scanf("%s", s) == 1) {
        // Iterate through each character of the string
        for (int i = 0; s[i] != '\0'; i++) {
            // Check if character is a digit
            if (isdigit(s[i])) {
                // Convert char digit to integer index (e.g., '5' - '0' = 5)
                count[s[i] - '0']++;
            }
        }

        // Print the frequencies separated by spaces
        for (int i = 0; i < 10; i++) {
            printf("%d%s", count[i], (i == 9 ? "" : " "));
        }
        printf("\n");
    }

    return 0;
}

